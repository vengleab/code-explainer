{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "builds": [
    {
      "src": "backend/generate.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["backend/fonts/**"],
        "maxDuration": 10
      }
    },
    {
      "src": "backend/generate_pandas.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["backend/fonts/**"],
        "maxDuration": 10
      }
    }
  ],
  "routes": [
    { "src": "/api/generate-pandas", "dest": "backend/generate_pandas.py" },
    { "src": "/api/(.*)",            "dest": "backend/generate.py" },
    { "src": "/(.*)",                "dest": "/$1" }
  ]
}
